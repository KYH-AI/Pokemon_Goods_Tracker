      "api_key_env": "BRICKECONOMY_API_KEY",
      "enabled": false,
      "request_delay_sec": 1,
      "note": "유료 Premium 구독 전용 API — 무료 플랜 없음. 활성화 시 BRICKECONOMY_API_KEY 필요. premium_pct는 번개장터/정가 fallback으로 대체됨"
    },
    "lego_official": {
      "base_url": "https://www.lego.com",
      "product_url": "https://www.lego.com/ko-kr/product/{set_number}",
