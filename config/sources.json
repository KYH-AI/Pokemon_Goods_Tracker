    "pricecharting": {
      "base_url": "https://www.pricecharting.com",
      "product_url": "https://www.pricecharting.com/game/{pricecharting_id}",
      "enabled": true,
      "request_delay_sec": 2
    },
    "ebay": {
      "browse_api_url": "https://api.ebay.com/buy/browse/v1/item_summary/search",
      "fallback_search_url": "https://www.ebay.com/sch/i.html",
      "sold_filter_params": "LH_Complete=1&LH_Sold=1",
      "enabled": true,
      "request_delay_sec": 1,
      "sold_days_back": 30
    },
    "naver_cafe": {
      "search_url": "https://cafe.naver.com/ArticleSearchList.nhn",
      "target_cafes": [
        {"name": "포켓몬 트레이딩 카드 게임", "id": "pokeca"},
        {"name": "포켓몬 코리아 팬 카페", "id": "pokemonfan"}
      ],
      "enabled": true,
      "request_delay_sec": 1,
      "login_required": false
    },
    "bunjang": {
      "search_url": "https://m.bunjang.co.kr/search/products",
      "enabled": true,
      "request_delay_range": [3, 5],
      "fee_percent": 6
    },
    "daangn": {
      "search_url": "https://www.daangn.com/search",
      "enabled": true,
      "request_delay_range": [5, 8]
    }
  },
  "lego_sources": {
